// U-Rest schema — identity/KYC/payout slice (Phase 1; ADR-007, ADR-010).
// Listings/bookings/ledger arrive in Phases 2–3 (PRODUCT_FLOWS.md is the contract).
//
// Conventions (CLAUDE.md): money = Int satang · DateTime = UTC timestamptz ·
// state transitions only via lib/ modules · NEVER store the Thai national ID
// number in any form (ADR-010) · sensitive fields end in `Enc` and hold
// AES-256-GCM ciphertext from src/lib/crypto.ts — never plaintext.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector, btree_gist] // pgvector (semantic search, Phase 2+) + btree_gist (Season GiST exclusion — DATA_MODEL.md)
}

// ───────────────────────── Identity (guests + hosts — one account, ADR-007) ─────

// ───────────────────────── Listings domain (Phase 2 — ADR-011, DATA_MODEL.md) ──

/// Lookup table, not an enum: region expansion (Pattaya → region 2) is a
/// planned GTM event — launching เขาใหญ่ is an INSERT, not a deploy.
model Region {
  id        String  @id @default(cuid())
  slug      String  @unique // "pattaya"
  nameTh    String
  nameEn    String
  centerLat Float
  centerLng Float
  /// GTM gating (BUSINESS_PLAN §7): only Pattaya active at launch
  isActive  Boolean @default(false)
  sortOrder Int     @default(0)

  listings    Listing[]
  attractions Attraction[]
}

enum ListingStatus {
  DRAFT
  PENDING_REVIEW
  NEEDS_INFO
  PUBLISHED
  UNLISTED
  REJECTED
}

enum Amenity {
  PRIVATE_POOL
  KARAOKE
  BBQ
  PET_FRIENDLY
  POOL_SLIDE
  KITCHEN
  PARKING
  WIFI
  POOL_TABLE
  NETFLIX
  WHEELCHAIR_ACCESS
}

enum PartyPolicy {
  ALLOWED
  ASK_FIRST
  FORBIDDEN
}

enum CancellationTier {
  FLEXIBLE
  MODERATE
  STRICT
}

enum BookingMode {
  REQUEST
  INSTANT
}

/// Status transitions ONLY via lib/listing (CLAUDE.md rule 2) — mirrors
/// PRODUCT_FLOWS §2.2 verbatim. Money fields are Int satang (rule 1).
model Listing {
  id       String        @id @default(cuid())
  hostId   String
  regionId String
  status   ListingStatus @default(DRAFT)

  // basics (wizard ①)
  title        String
  description  String @default("")
  address      String @default("")
  mapLat       Float?
  mapLng       Float?
  propertyType String @default("pool_villa")

  // details (wizard ③)
  bedrooms    Int       @default(1)
  beds        Int       @default(1)
  baths       Int       @default(1)
  maxGuests   Int       @default(2)
  poolLengthM Decimal?  @db.Decimal(4, 2)
  poolWidthM  Decimal?  @db.Decimal(4, 2)
  poolDepthM  Decimal?  @db.Decimal(4, 2)
  amenities   Amenity[]

  // house rules (wizard ④)
  partyPolicy       PartyPolicy @default(ASK_FIRST)
  quietHoursStart   String? // "22:00" — zone-free by design
  quietHoursEnd     String?
  /// Cash damage deposit at check-in — never through the platform (§2.3)
  cashDepositSatang Int         @default(0)
  checkInTime       String      @default("15:00")
  checkOutTime      String      @default("11:00")

  // pricing & mode (wizard ⑤) — live source for NEW quotes only;
  // bookings snapshot everything at request time (ADR-011)
  includedGuests      Int              @default(2)
  extraGuestFeeSatang Int              @default(0)
  baseWeekdaySatang   Int              @default(0)
  baseWeekendSatang   Int              @default(0)
  /// One rate for public holidays + eves (resolution: holiday > season > base)
  holidaySatang       Int?
  cancellationTier    CancellationTier @default(MODERATE)
  bookingMode         BookingMode      @default(REQUEST)
  /// Timestamp of the §4.1 stale-calendar strike acknowledgment (instant mode)
  instantAckAt        DateTime?

  /// ถูกต้องตามกฎหมาย badge granted (hotel license / non-hotel registration)
  legalBadgeAt DateTime?
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  /// Denormalized review aggregate (§3.4 display) — recomputed by lib/reviews on
  /// publish/removal; null avgRating until the first published review.
  avgRating   Float?
  reviewCount Int    @default(0)

  host           User              @relation(fields: [hostId], references: [id])
  region         Region            @relation(fields: [regionId], references: [id])
  photos         ListingPhoto[]
  seasons        Season[]
  calendarBlocks CalendarBlock[]
  faqEntries     ListingFaqEntry[]
  savedBy        SavedVilla[]
  kycSubmissions KycSubmission[]
  bookings       Booking[]
  reports        Report[]

  @@index([regionId, status])
  @@index([hostId, status])
  // GIN index for amenity-filter search. Declared so Prisma owns it (no migrate
  // drift); the raw migration creates it under this same name (DATA_MODEL.md).
  @@index([amenities], type: Gin, map: "Listing_amenities_gin")
}

model ListingPhoto {
  id        String  @id @default(cuid())
  listingId String
  /// PUBLIC bucket key (KYC docs use the private bucket — never mix)
  r2Key     String
  sortOrder Int     @default(0)
  isCover   Boolean @default(false)

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, sortOrder])
}

/// Host-defined named season with its own rates (§4.1 ⑤). Overlap is
/// IMPOSSIBLE at the DB level: GiST exclusion constraint in raw migration
/// SQL (see DATA_MODEL.md §constraints) + friendly app check in lib/listing.
model Season {
  id            String   @id @default(cuid())
  listingId     String
  nameTh        String
  startDate     DateTime @db.Date
  endDate       DateTime @db.Date
  weekdaySatang Int
  weekendSatang Int

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

/// System-maintained Thai public holidays (§4.1: hosts never track Songkran).
/// Quote engine prices a night as holiday if date ∈ table OR date+1 ∈ table (eves).
model ThaiHoliday {
  date   DateTime @id @db.Date
  nameTh String
}

/// Host manual calendar blocks. Block-vs-booking conflicts are checked in
/// lib/listing; booking-vs-booking is the Phase 3 exclusion constraint's job.
model CalendarBlock {
  id        String   @id @default(cuid())
  listingId String
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  note      String?

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, startDate])
}

enum FaqSource {
  HOST
  ADMIN_SUGGESTED
}

enum FaqStatus {
  DRAFT
  PUBLISHED
}

/// Per-listing Q&A (§4.1) — served to น้องเรสต์ via get_listing_details;
/// every entry shrinks the AI's "ไม่มีข้อมูล" rate (the §5.7 growth loop).
model ListingFaqEntry {
  id        String    @id @default(cuid())
  listingId String
  question  String
  answer    String
  source    FaqSource @default(HOST)
  status    FaqStatus @default(PUBLISHED)
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, status])
}

/// ♡ saved villas (§3.1, grill #4): flat list, login-gated.
model SavedVilla {
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@id([userId, listingId])
  @@index([userId, createdAt])
}

enum AttractionCategory {
  FOOD
  BEACH
  ACTIVITY
  SHOPPING
}

/// Curated POIs (§3.1 ที่เที่ยวใกล้ๆ + Phase 4 get_nearby_attractions).
/// Distance computed at query time from lat/lng. Embedding column lands in
/// Phase 4 with the embedding-model choice.
model Attraction {
  id       String             @id @default(cuid())
  regionId String
  nameTh   String
  category AttractionCategory
  lat      Float
  lng      Float
  descTh   String             @default("")
  isActive Boolean            @default(true)

  region Region @relation(fields: [regionId], references: [id])

  @@index([regionId, category])
}

enum NotificationChannel {
  LINE
  EMAIL
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
}

/// Channel-of-record log (ADR-005): every send recorded; FAILED rows retried
/// by the cron sweep; doubles as the LINE quota monitor.
model NotificationLog {
  id          String              @id @default(cuid())
  userId      String?
  channel     NotificationChannel
  templateKey String
  payload     Json
  status      NotificationStatus  @default(QUEUED)
  attempts    Int                 @default(0)
  lastError   String?
  createdAt   DateTime            @default(now())
  sentAt      DateTime?

  user User? @relation(fields: [userId], references: [id])

  @@index([status, createdAt])
}

// ───────────────────────── Identity (guests + hosts — one account, ADR-007) ─────

model User {
  id                String    @id @default(cuid())
  lineUserId        String?   @unique
  displayName       String
  /// PII columns are nullable so PDPA anonymization can scrub them (§3.7:
  /// delete is soft + anonymized when bookings exist — ledger integrity).
  email             String?   @unique
  phone             String?
  /// Set only by the OTP flow — gates sending requests/messages (ladder step 2).
  phoneVerifiedAt   DateTime?
  image             String?
  /// LINE/email per event group (§3.7) — shape owned by lib/notifications.
  notificationPrefs Json?

  suspendedAt  DateTime? // §5.4: can't transact; existing bookings honored
  deletedAt    DateTime? // soft delete
  anonymizedAt DateTime? // PII scrubbed; row retained for ledger references

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts         Account[]
  sessions         Session[]
  phoneOtps        PhoneOtp[]
  kycSubmissions   KycSubmission[]
  payoutAccounts   PayoutAccount[]
  consents         Consent[]
  listings         Listing[]
  savedVillas      SavedVilla[]
  notificationLogs NotificationLog[]

  // Phase 3 (booking/escrow) — guest-side bookings + host accountability
  bookings             Booking[]
  hostStrikes          HostStrike[]
  payoutHolds          PayoutHold[]
  messagesSent         Message[]
  reviewsWritten       Review[]
  guestRatingsGiven    GuestRating[] @relation("GuestRatingsGiven")
  guestRatingsReceived GuestRating[] @relation("GuestRatingsReceived")
  reportsSubmitted     Report[]      @relation("ReportsSubmitted")
  reportsReceived      Report[]      @relation("ReportsReceived")

  // Phase 4 (AI concierge)
  conciergesessions ConciergeSession[]
}

// Auth.js (Prisma adapter) — database sessions: revocable, so suspend/ban
// takes effect immediately (ADR-010).

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

/// Phone OTP (verification ladder step 2). Codes stored as sha256 hashes only;
/// expired/consumed rows removed by the cron sweep (ADR-004 pattern).
model PhoneOtp {
  id         String    @id @default(cuid())
  userId     String
  /// sha256(code + per-row salt embedded in hash string) — never the code itself
  codeHash   String
  phone      String
  expiresAt  DateTime
  attempts   Int       @default(0)
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

// ───────────────────────── Admin (separate auth surface — ADR-007/010) ─────────
// Deliberately NOT related to User: an authz bug in guest/host code cannot
// reach admin powers. Created manually (seed script), no self-signup.

model AdminUser {
  id            String    @id @default(cuid())
  email         String    @unique
  /// argon2id hash (set by the admin seed/management script, Phase 2)
  passwordHash  String
  /// TOTP secret — AES-256-GCM ciphertext via lib/crypto.ts, never plaintext
  totpSecretEnc String?
  displayName   String
  disabledAt    DateTime?
  createdAt     DateTime  @default(now())

  kycReviews KycSubmission[]
  auditLogs  AuditLog[]

  // Phase 3 — admin acts on the money/trust surface
  payoutsPaid         Payout[]
  payoutHoldsCreated  PayoutHold[] @relation("PayoutHoldsCreated")
  payoutHoldsReleased PayoutHold[] @relation("PayoutHoldsReleased")
  reviewsRemoved      Review[]
  reportsTriaged      Report[]
}

// ───────────────────────── KYC & payouts (PRODUCT_FLOWS §4.1 ⑥, §5.1) ──────────

enum KycStatus {
  PENDING_REVIEW
  NEEDS_INFO
  APPROVED
  REJECTED
}

enum KycDocumentType {
  THAI_ID
  RIGHT_TO_RENT
  SELFIE
  /// Optional ถูกต้องตามกฎหมาย badge upload (hotel license / non-hotel registration)
  HOTEL_LICENSE
}

/// One submission per listing (§1: KYC reviewed per listing; returning hosts
/// with clean history get lighter review — history is visible via prior rows).
model KycSubmission {
  id                String    @id @default(cuid())
  userId            String
  listingId         String?
  status            KycStatus @default(PENDING_REVIEW)
  /// Itemized NEEDS_INFO checklist (§5.1) — array of {item, note?, satisfied}
  needsInfoItems    Json?
  reviewedByAdminId String?
  submittedAt       DateTime  @default(now())
  reviewedAt        DateTime?

  user       User          @relation(fields: [userId], references: [id])
  listing    Listing?      @relation(fields: [listingId], references: [id])
  reviewedBy AdminUser?    @relation(fields: [reviewedByAdminId], references: [id])
  documents  KycDocument[]

  @@index([status, submittedAt]) // approval queue, SLA ordering
  @@index([userId])
}

/// One row per uploaded document. r2Key points into the PRIVATE bucket —
/// never store URLs, never serve except via short-lived signed URLs to admin.
model KycDocument {
  id           String          @id @default(cuid())
  submissionId String
  type         KycDocumentType
  r2Key        String
  uploadedAt   DateTime        @default(now())
  /// Set when the parent submission is rejected/withdrawn: now + 90 days
  /// (ADR-007). The purge cron deletes the R2 object AND this row.
  purgeAfter   DateTime?

  submission KycSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([purgeAfter])
}

/// Host bank account for manual payout runs (§5.2). Reusable across the
/// host's listings; editing it triggers listing re-review (§4.4).
model PayoutAccount {
  id               String    @id @default(cuid())
  userId           String
  /// Thai bank code (e.g. "004" กสิกรไทย) — public reference data, plaintext
  bankCode         String
  /// AES-256-GCM ciphertext (lib/crypto.ts). Decrypted in EXACTLY one code
  /// path: the admin payout view. Never logged, never sent to the client.
  accountNumberEnc String
  /// Account holder name — must match the name on the Thai ID (mule-account
  /// check, §4.1 ⑥). Needed plaintext for the payout run + name matching.
  accountName      String
  verifiedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  payouts Payout[]

  @@index([userId])
}

// ───────────────────────── Paper trail (append-only — ADR-010) ─────────────────
// No update/delete code paths exist for these tables, by convention and review.

enum ConsentType {
  TOS
  PRIVACY
  KYC_PROCESSING
}

model Consent {
  id            String      @id @default(cuid())
  userId        String
  type          ConsentType
  policyVersion String
  createdAt     DateTime    @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, type])
}

/// Every admin action (§5: who/what/when/before-after). KYC review, payout
/// marking, holds, suspensions — all write here in the same transaction.
model AuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetType String
  targetId   String
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())

  admin AdminUser @relation(fields: [adminId], references: [id])

  @@index([targetType, targetId])
  @@index([adminId, createdAt])
}

// ───────────────────────── Booking & escrow (Phase 3 — PRODUCT_FLOWS §2; ADR-003/011/012) ──
// State transitions ONLY via lib/booking (status) and lib/ledger (escrowState +
// the append-only LedgerEntry log). Money is Int satang. Timers are rows swept
// by cron, never setTimeout. Raw-SQL constraints (Booking double-booking GiST
// exclusion, Report/PayoutHold num_nonnulls CHECKs) are hand-appended to the
// migration — see docs/DATA_MODEL.md §constraints.

/// Booking lifecycle (PRODUCT_FLOWS §2.1 verbatim).
enum BookingStatus {
  REQUESTED
  AWAITING_PAYMENT
  CONFIRMED
  CHECKED_IN
  COMPLETED
  DECLINED
  EXPIRED
  CANCELLED_BY_GUEST
  CANCELLED_BY_HOST
  DISPUTED
}

/// Escrow/payout state (PRODUCT_FLOWS §2.3). Cached on Booking.escrowState;
/// the source of truth is the append-only LedgerEntry log (ADR-003).
enum EscrowState {
  NONE
  HELD
  RELEASABLE
  FROZEN
  PAID
  REVERSED
}

enum PaymentMethod {
  PROMPTPAY
  CARD
}

enum PaymentStatus {
  PENDING
  SUCCESSFUL
  FAILED
  EXPIRED
  REFUNDED // paid-race auto-refund (#22): charge succeeded after the booking expired
}

/// Why a LedgerEntry was written (ADR-003 §2 — no orphan transitions). One value
/// per escrow transition lib/ledger can make.
enum LedgerCause {
  CHARGE_WEBHOOK // NONE → HELD (Opn charge succeeded)
  RELEASE_CHECKOUT // HELD → RELEASABLE (checkout, no dispute)
  HOLD_DISPUTE_OPENED // → FROZEN (guest opened a dispute)
  HOLD_BOOKING_REPORT // → FROZEN (booking report taken into review)
  HOLD_ADMIN_MANUAL // → FROZEN (admin manual hold)
  RELEASE_HOLD_LIFTED // FROZEN → RELEASABLE (hold lifted / dispute released)
  PAID_ADMIN_TRANSFER // RELEASABLE → PAID (admin bank transfer)
  REFUND_GUEST_TIER // → REVERSED (guest cancellation, per policy tier)
  REFUND_HOST_CANCELLED // → REVERSED (host cancelled, 100%)
  REFUND_DISPUTE_FULL // → REVERSED (dispute resolved, full refund)
  REFUND_DISPUTE_PARTIAL // → REVERSED (dispute resolved, partial refund)
}

enum DisputeStatus {
  OPEN
  RESOLVED_RELEASED
  RESOLVED_PARTIAL
  RESOLVED_REFUNDED
}

enum ReportCategory {
  DOESNT_MATCH_LISTING
  CLEANLINESS
  SAFETY
  HOST_BEHAVIOR
  SUSPECTED_FRAUD
  OTHER
}

enum ReportStatus {
  RECEIVED
  IN_REVIEW
  RESOLVED
  DISMISSED
}

enum HostStrikeReason {
  HOST_CANCELLED // host cancelled a CONFIRMED booking (ADR-012 §2)
  STALE_CALENDAR_DOUBLE_BOOKING // stale calendar double-booked a paid guest
}

/// A booking. Status moves only through lib/booking; escrowState only through
/// lib/ledger. The snapshot block (priceLines…houseRulesText) freezes the agreed
/// terms so later host edits can't move an in-flight booking (ADR-011 №3).
model Booking {
  id          String        @id @default(cuid())
  /// UR-YYMM-NNNN — assigned at CONFIRMED via BookingCodeCounter (lib/ledger).
  code        String?       @unique
  listingId   String
  userId      String
  status      BookingStatus @default(REQUESTED)
  bookingMode BookingMode

  // stay dates — date-only; platform check-in 15:00 / checkout 11:00 Bangkok.
  checkIn  DateTime @db.Date
  checkOut DateTime @db.Date

  // deadline timers — rows swept by cron (rule 3), never in-process setTimeout.
  respondBy DateTime? // host accept deadline (REQUESTED + 12h)
  payBy     DateTime? // payment deadline (12h request / 1h instant)
  payReminderSentAt DateTime? // once-only "payment 2h left" reminder marker (#21)

  // snapshot block (ADR-011 №3) — frozen at request time.
  priceLines       Json
  totalSatang      Int
  commissionSatang Int
  cancellationTier CancellationTier
  houseRulesText   String?
  guestNoteToHost  String?

  // escrow cache — written ONLY by lib/ledger (ADR-003).
  escrowState       EscrowState @default(NONE)
  contactUnmaskedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listing       Listing        @relation(fields: [listingId], references: [id])
  user          User           @relation(fields: [userId], references: [id])
  payments      Payment[]
  ledgerEntries LedgerEntry[]
  refund        Refund?
  payout        Payout?
  payoutHolds   PayoutHold[]
  hostStrikes   HostStrike[]
  messageThread MessageThread?
  review        Review?
  guestRating   GuestRating?
  dispute       Dispute?
  reports       Report[]

  @@index([status, respondBy]) // sweep: host-accept expiry
  @@index([status, payBy]) // sweep: payment expiry
  @@index([escrowState, checkOut]) // payout due-list
  @@index([listingId, checkIn]) // double-booking lookups
  @@index([userId])
}

/// One row per calendar month; counter incremented under SELECT … FOR UPDATE
/// inside the confirm transaction to mint gap-free UR-YYMM-NNNN codes.
model BookingCodeCounter {
  yearMonth String @id // "2606"
  counter   Int    @default(0)
}

/// One row per charge attempt — a regenerated PromptPay QR is a new row.
model Payment {
  id           String        @id @default(cuid())
  bookingId    String
  opnChargeId  String        @unique
  method       PaymentMethod
  amountSatang Int
  status       PaymentStatus @default(PENDING)
  qrExpiresAt  DateTime? // PromptPay QR validity (15 min), regenerable
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}

/// Opn webhook idempotency (rule 6): the event id is recorded before processing;
/// replays short-circuit on the unique constraint.
model WebhookEvent {
  id          String    @id @default(cuid())
  opnEventId  String    @unique
  payload     Json
  processedAt DateTime?
  createdAt   DateTime  @default(now())
}

/// Append-only escrow log (ADR-003): every satang movement is a new row, never
/// an UPDATE. Booking.escrowState is a cache derived from the latest toState.
model LedgerEntry {
  id           String       @id @default(cuid())
  bookingId    String
  amountSatang Int
  fromState    EscrowState?
  toState      EscrowState
  cause        LedgerCause
  /// Opn event id, AdminUser id, Dispute id, etc. — who/what authorized it.
  causeRef     String?
  actor        String?
  createdAt    DateTime     @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, createdAt])
}

/// Money returned to the guest + retained split (90/10 host/platform, §3.6).
model Refund {
  id                     String   @id @default(cuid())
  bookingId              String   @unique
  refundSatang           Int
  retainedHostSatang     Int
  retainedPlatformSatang Int
  reason                 String?
  opnRefundId            String?  // set when the Opn refund lands; NULL = owed-but-not-moved (reconciliation, #23)
  createdAt              DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

/// Manual payout run v1 (§5.2): admin transfers by bank app, records the slip.
model Payout {
  id               String    @id @default(cuid())
  bookingId        String    @unique
  payoutAccountId  String
  hostAmountSatang Int
  slipRef          String?
  paidByAdminId    String?
  paidAt           DateTime?
  createdAt        DateTime  @default(now())

  booking       Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  payoutAccount PayoutAccount @relation(fields: [payoutAccountId], references: [id])
  paidByAdmin   AdminUser?    @relation(fields: [paidByAdminId], references: [id])

  @@index([payoutAccountId])
}

/// Admin hold on payouts — scoped to exactly one of a single booking OR a whole
/// host (CHECK num_nonnulls = 1, constraint №4). The due-list skips active holds.
model PayoutHold {
  id                String    @id @default(cuid())
  bookingId         String?
  hostUserId        String?
  reason            String
  createdByAdminId  String
  releasedByAdminId String?
  releasedAt        DateTime?
  createdAt         DateTime  @default(now())

  booking    Booking?   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  host       User?      @relation(fields: [hostUserId], references: [id], onDelete: Cascade)
  createdBy  AdminUser  @relation("PayoutHoldsCreated", fields: [createdByAdminId], references: [id])
  releasedBy AdminUser? @relation("PayoutHoldsReleased", fields: [releasedByAdminId], references: [id])

  @@index([bookingId])
  @@index([hostUserId])
}

/// Host accountability (ADR-012 §2): 3 strikes → suspension (enforced in lib/booking).
model HostStrike {
  id         String           @id @default(cuid())
  hostUserId String
  bookingId  String?
  reason     HostStrikeReason
  createdAt  DateTime         @default(now())

  host    User     @relation(fields: [hostUserId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([hostUserId, createdAt])
}

// ───────────────────────── Social (Phase 3 — schema only; logic in #24/#26/#27/#28) ─────

/// Per-booking thread, opens at REQUESTED (§3.5).
model MessageThread {
  id             String    @id @default(cuid())
  bookingId      String    @unique
  lastNotifiedAt DateTime? // 1/thread/10min LINE-push throttle, CAS-claimed (#24)
  createdAt      DateTime  @default(now())

  booking  Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  messages Message[]
}

/// Masking frozen at write (ADR-011 №5): bodyRaw readable ONLY in the admin
/// dispute view; everyone else sees bodyMasked.
model Message {
  id         String    @id @default(cuid())
  threadId   String
  senderId   String
  bodyRaw    String
  bodyMasked String
  wasMasked  Boolean   @default(false)
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  thread MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User          @relation(fields: [senderId], references: [id])

  @@index([threadId, createdAt])
}

/// Guest review (§3.4): overall + 4 sub-scores; one per booking, no edits;
/// removal is soft moderation (reason in AuditLog).
model Review {
  id                 String    @id @default(cuid())
  bookingId          String    @unique
  authorId           String
  overall            Int
  cleanliness        Int
  accuracyToPhotos   Int
  hostResponsiveness Int
  valueForMoney      Int
  text               String?
  photoKeys          String[]
  removedByAdminId   String?
  removedAt          DateTime?
  removedReason      String?
  createdAt          DateTime  @default(now())

  booking   Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  author    User       @relation(fields: [authorId], references: [id])
  removedBy AdminUser? @relation(fields: [removedByAdminId], references: [id])
  reports   Report[]
}

/// Host → guest rating (§3.4), shown to future hosts on a request.
model GuestRating {
  id           String   @id @default(cuid())
  bookingId    String   @unique
  hostRaterId  String
  guestRateeId String
  score        Int // 1–5
  reason       String?
  createdAt    DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  rater   User    @relation("GuestRatingsGiven", fields: [hostRaterId], references: [id])
  ratee   User    @relation("GuestRatingsReceived", fields: [guestRateeId], references: [id])

  @@index([guestRateeId])
}

/// Dispute opened during the stay (§5.3). Window = check-in → checkout;
/// one appeal each, enforced in lib/booking.
model Dispute {
  id               String        @id @default(cuid())
  bookingId        String        @unique
  status           DisputeStatus @default(OPEN)
  partialRefundPct Int? // 0–100 when RESOLVED_PARTIAL
  guestAppealedAt  DateTime?
  hostAppealedAt   DateTime?
  createdAt        DateTime      @default(now())
  resolvedAt       DateTime?

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

/// The §5.6 report queue. Targets exactly one of booking/listing/review/user
/// (CHECK num_nonnulls = 1, constraint №3). reporterId is null for logged-out
/// listing reports.
model Report {
  id              String         @id @default(cuid())
  reporterId      String?
  category        ReportCategory
  text            String
  photoKeys       String[]
  bookingId       String?
  listingId       String?
  reviewId        String?
  reportedUserId  String?
  status          ReportStatus   @default(RECEIVED)
  resolvedReason  String?
  triageByAdminId String?
  triageAt        DateTime?
  resolvedAt      DateTime?
  createdAt       DateTime       @default(now())

  reporter     User?      @relation("ReportsSubmitted", fields: [reporterId], references: [id])
  booking      Booking?   @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  listing      Listing?   @relation(fields: [listingId], references: [id], onDelete: SetNull)
  review       Review?    @relation(fields: [reviewId], references: [id], onDelete: SetNull)
  reportedUser User?      @relation("ReportsReceived", fields: [reportedUserId], references: [id])
  triageBy     AdminUser? @relation(fields: [triageByAdminId], references: [id])

  @@index([status, createdAt])
}

// ───────────────────────── Concierge domain (Phase 4 — AI_CONCIERGE_SPEC §5) ──

/// AI chat session. userId nullable for pre-login browsing; scopedListingId
/// set when opened from a listing page ("ถามน้องเรสต์เกี่ยวกับที่พักนี้").
model ConciergeSession {
  id              String   @id @default(cuid())
  userId          String?
  scopedListingId String?
  createdAt       DateTime @default(now())

  user                User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  messages            ConciergeMessage[]
  usage               ConciergeUsage[]
  unansweredQuestions UnansweredQuestion[]
  bookingDrafts       ConciergeBookingDraft[]

  @@index([userId, createdAt])
}

/// In-chat booking draft + its server-side confirmation token (#32, AI_CONCIERGE_SPEC §3).
/// The model is handed only `id` (draft_id); the token fields are minted on the
/// guest's tap and are NEVER seen by the model. `consumedBookingId` makes submit
/// single-use. The price snapshot mirrors the Booking it creates (ADR-011 №3).
model ConciergeBookingDraft {
  id                    String           @id @default(cuid())
  sessionId             String
  userId                String
  listingId             String
  checkIn               DateTime         @db.Date
  checkOut              DateTime         @db.Date
  guests                Int
  priceLines            Json
  totalSatang           Int
  commissionSatang      Int
  cancellationTier      CancellationTier
  guestNoteToHost       String?
  createdAt             DateTime         @default(now())
  expiresAt             DateTime
  confirmedAt           DateTime?
  confirmTokenHash      String?
  confirmTokenExpiresAt DateTime?
  consumedBookingId     String?

  session ConciergeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// One row per AI turn. 12-month purge by nightly cron (ADR-004 sweep pattern).
model ConciergeMessage {
  id        String   @id @default(cuid())
  sessionId String
  /// Anthropic SDK roles: "user" | "assistant" | "tool"
  role      String
  content   String
  /// Raw tool call / result structure from the SDK (nullable)
  toolCalls Json?
  createdAt DateTime @default(now())

  session ConciergeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([createdAt]) // 12-month purge sweep
}

/// Token + cost accounting per session. Feeds the monthly kill switch.
/// Money rule: costSatang is Int satang (1 THB = 100 satang).
model ConciergeUsage {
  id                   String   @id @default(cuid())
  sessionId            String
  inputTokens          Int      @default(0)
  outputTokens         Int      @default(0)
  /// Anthropic usage.cache_read_input_tokens — logged for caching verification (§8)
  cacheReadInputTokens Int      @default(0)
  costSatang           Int      @default(0)
  createdAt            DateTime @default(now())

  session ConciergeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt]) // monthly budget kill-switch query
}

enum UnansweredQuestionStatus {
  OPEN
  CONVERTED
  DISMISSED
}

/// Written whenever the refusal path fires (§5); feeds the §5.7 admin growth loop.
model UnansweredQuestion {
  id           String                   @id @default(cuid())
  sessionId    String
  listingId    String?
  questionText String
  status       UnansweredQuestionStatus @default(OPEN)
  createdAt    DateTime                 @default(now())

  session ConciergeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([listingId, status])
}
