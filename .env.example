# Copy to .env for local development. NEVER commit .env.
# Every variable here must also be declared in src/lib/env.ts (validated at boot).

# Local Postgres via docker-compose (pnpm db:up)
DATABASE_URL="postgresql://urest:urest@localhost:5432/urest"

# Field encryption (ADR-010): 32 bytes base64. Generate a UNIQUE key per env:
#   node -e "console.log(crypto.randomBytes(32).toString('base64'))"
# Losing the production key = losing every encrypted field. Back it up securely.
DATA_ENCRYPTION_KEY="REPLACE_ME_generate_your_own_32_byte_base64_key"

# --- Phase 1: auth (LINE Developers console) ---
# Callback URL to register on the LINE Login channel (NOT locale-prefixed):
#   http://localhost:3000/api/auth/callback/line   (+ the Railway prod URL)
AUTH_SECRET=""            # openssl rand -base64 32
LINE_CLIENT_ID=""         # LINE Login channel ID
LINE_CLIENT_SECRET=""     # LINE Login channel secret

