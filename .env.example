# Copy to .env for local development. NEVER commit .env.
# Every variable here must also be declared in src/lib/env.ts (validated at boot).

# Local Postgres via docker-compose (pnpm db:up)
DATABASE_URL="postgresql://urest:urest@localhost:5432/urest"

# Field encryption (ADR-010): 32 bytes base64. Generate a UNIQUE key per env:
#   node -e "console.log(crypto.randomBytes(32).toString('base64'))"
# Losing the production key = losing every encrypted field. Back it up securely.
DATA_ENCRYPTION_KEY="REPLACE_ME_generate_your_own_32_byte_base64_key"

# --- Phase 1: auth — multi-provider login (ADR-007: email/password + Google/Facebook/LINE) ---
# Google is the ACTIVE provider (LINE disabled); Facebook/email follow in later PRs.
# Google is the ACTIVE login provider. Redirect URI to register on the Google
# Cloud OAuth 2.0 client (NOT locale-prefixed):
#   http://localhost:3000/api/auth/callback/google   (+ the Railway prod URL)
# Authorized JS origin: http://localhost:3000 (+ prod). Dev keys: use the SHARED
# "U-Rest Dev" Google OAuth client (from the founders' password manager) — same
# values for every dev. Production uses a SEPARATE client whose keys live only in
# Railway runtime env (never here).
AUTH_SECRET=""            # openssl rand -base64 32
# Public origin Auth.js builds OAuth callbacks from. Dev may omit (localhost is
# auto-detected); PRODUCTION MUST set it to the public URL — otherwise the callback
# uses the 0.0.0.0:8080 bind host behind Railway and Google rejects redirect_uri.
# Must exactly match a URI registered in the Google Cloud OAuth client.
AUTH_URL="http://localhost:3000"
# Admin session HMAC secret (ADR-007/010) — SEPARATE from AUTH_SECRET so the
# /admin surface shares no signing material with the consumer auth path:
ADMIN_SESSION_SECRET=""   # openssl rand -base64 32
GOOGLE_CLIENT_ID=""       # Google Cloud console — OAuth 2.0 client ID
GOOGLE_CLIENT_SECRET=""   # Google Cloud console — OAuth 2.0 client secret
# LINE login is DISABLED for now (optional). To re-enable: set these + restore
# the LINE provider in src/lib/auth/auth.config.ts.
# LINE_CLIENT_ID=""         # LINE Login channel ID
# LINE_CLIENT_SECRET=""     # LINE Login channel secret
# FACEBOOK_CLIENT_ID=""     # Meta for Developers (Facebook Login app)
# FACEBOOK_CLIENT_SECRET=""

# --- Media storage: Cloudflare R2 (ADR-002/010, issue #11) ---
# Two buckets: PUBLIC (listing photos, CDN-served) + PRIVATE (KYC docs, signed
# URLs only). Account id, a scoped S3 API token, and the public CDN domain.
R2_ACCOUNT_ID=""              # Cloudflare account id
R2_ACCESS_KEY_ID=""          # R2 API token (S3) access key id
R2_SECRET_ACCESS_KEY=""      # R2 API token (S3) secret
R2_PUBLIC_BUCKET=""          # e.g. urest-public
R2_PRIVATE_BUCKET=""         # e.g. urest-kyc  (NOT public — never attach a CDN)
R2_PUBLIC_BASE_URL=""        # public bucket CDN/custom domain, e.g. https://media.urest.app

# --- Phase 2: listings ---
# HTTP referrer restricted to prod domain + localhost; $0 budget cap set in Google Cloud billing (ADR-009)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# --- Phase 3: payments (Opn dashboard → API keys; TEST keys until launch gate; ADR-001, #20) ---
OPN_PUBLIC_KEY="pkey_test_..."   # publishable key — client-side card tokenization
OPN_SECRET_KEY="skey_test_..."   # secret key — server charges + webhook re-fetch (never client/logs)
# OPN_API_BASE=http://localhost:4100   # leave unset in real envs (defaults to https://api.omise.co); E2E points it at the local mock (#29)

# --- Notifications: Resend email + LINE push (ADR-005); optional — console driver until set ---
# RESEND_API_KEY="re_..."                 # Resend dashboard → API keys (email = channel of record)
# LINE_CHANNEL_ACCESS_TOKEN="..."         # LINE OA Messaging API channel access token (push)

# --- Phase 4: AI concierge ---
ANTHROPIC_API_KEY=""
CONCIERGE_MODEL="claude-haiku-4-5"
CONCIERGE_BUDGET_SATANG="50000"     # ฿500/month kill switch
CONCIERGE_DAILY_MSG_LIMIT="30"      # per-user daily message cap
